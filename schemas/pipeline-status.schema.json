{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pipeline Status",
  "description": "Telemetry state for a GSD-managed app. Written by Hermes, read by GSD Hub.",
  "type": "object",
  "required": ["app", "version", "updated_at", "active_feature", "deployed_features", "queued_features", "metrics"],
  "properties": {
    "app": {
      "type": "object",
      "required": ["slug", "name", "url"],
      "properties": {
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "repo": { "type": "string" },
        "local_path": { "type": "string" }
      }
    },
    "version": { "type": "string", "description": "Semantic version, increments per deployed feature" },
    "updated_at": { "type": "string", "format": "date-time" },
    "active_feature": {
      "description": "Currently running feature, or null if idle",
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "name", "started_at", "current_phase", "phases", "tasks", "rework_count"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "started_at": { "type": "string", "format": "date-time" },
            "current_phase": {
              "type": "string",
              "enum": ["RESEARCH", "BUSINESS_VALIDATION", "ARCHITECTURE", "UX_DESIGN", "PLAN", "EXECUTE", "UX_REVIEW", "TEST", "VERIFY", "DEPLOY"]
            },
            "phases": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "status"],
                "properties": {
                  "name": { "type": "string" },
                  "status": { "type": "string", "enum": ["pending", "in_progress", "passed", "failed"] },
                  "started_at": { "type": ["string", "null"], "format": "date-time" },
                  "completed_at": { "type": ["string", "null"], "format": "date-time" },
                  "duration_sec": { "type": ["integer", "null"] },
                  "result": { "type": ["string", "null"] },
                  "ux_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 60 }
                }
              }
            },
            "tasks": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "title", "status"],
                "properties": {
                  "id": { "type": "string" },
                  "title": { "type": "string" },
                  "status": { "type": "string", "enum": ["pending", "in_progress", "completed", "failed"] },
                  "assignee": { "type": "string" },
                  "delegate_id": { "type": ["string", "null"] },
                  "dependencies": { "type": "array", "items": { "type": "string" } },
                  "started_at": { "type": ["string", "null"], "format": "date-time" },
                  "completed_at": { "type": ["string", "null"], "format": "date-time" },
                  "files_count": { "type": ["integer", "null"] },
                  "lines_count": { "type": ["integer", "null"] }
                }
              }
            },
            "rework_count": { "type": "integer", "minimum": 0 },
            "ux_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 60 }
          }
        },
        { "type": "null" }
      ]
    },
    "deployed_features": {
      "type": "array",
      "description": "Completed features in deployment order",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "completed_at"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "version": { "type": "string" },
          "status": { "type": "string", "enum": ["deployed", "rolled_back"] },
          "completed_at": { "type": "string", "format": "date-time" },
          "ux_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 60 },
          "rework_count": { "type": "integer", "minimum": 0 },
          "tasks_total": { "type": "integer", "minimum": 0 },
          "duration_sec": { "type": ["integer", "null"] }
        }
      }
    },
    "queued_features": {
      "type": "array",
      "description": "Planned features waiting to start",
      "items": {
        "type": "object",
        "required": ["id", "name", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["planned", "blocked"] },
          "estimated_tasks": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [],
      "properties": {
        "features_total": { "type": "integer", "minimum": 0 },
        "features_deployed": { "type": "integer", "minimum": 0 },
        "tasks_total": { "type": "integer", "minimum": 0 },
        "tasks_completed": { "type": "integer", "minimum": 0 },
        "avg_ux_score": { "type": ["number", "null"], "minimum": 0, "maximum": 60 },
        "total_rework_count": { "type": "integer", "minimum": 0 },
        "total_duration_sec": { "type": ["integer", "null"] }
      }
    }
  }
}
